{
  "name": "jetpack",
  "version": "0.4.16",
  "title": "Jetpack",
  "author": "Earendel",
  "dependencies": [
    "base >= 2.0.58",
    "(?) PickerTweaks",
    "(?) YKR_inventory",
    "(?) YKR_inventory_100slot",
    "(?) YKR_inventory_500slot"
  ],
  "description": "Lets you build jetpack equipment that lets you rocket at high speeds to fly over buildings and water.",
  "factorio_version": "2.0",
  "homepage": "https://spaceexploration.miraheze.org",
  "package": {
    "git_publish_branch": "master",
    "ignore": ["**"],
    "extra": [
      { 
        "root": ".build"
      }
    ],
    "scripts": {
      "datestamp": "sh ./build-scripts/datestamp.sh",
      "prepackage": "sh ./build-scripts/prepackage.sh",
      "postpublish": "sh ./build-scripts/postpublish.sh"
    }
  }
}
